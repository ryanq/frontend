    flex: 1;
  }
}

.main-menu__item--try {
  @media (min-width: 64rem) {
    color: hsl(240 100% 50%);
  }
}

#more-toggle {
  display: none;
}

#more-toggle:checked {
  & ~ .primary-nav__menu-drawer .primary-nav__more-toggle::before {
    display: none;
  }

  & ~ .primary-nav__menu-drawer .primary-nav__more-drawer {
    display: block;
  }
}

.primary-nav__more-toggle {
  display: flex;
  gap: 0.5rem;
  align-items: center;

  user-select: none;
}

.primary-nav__more-toggle::before {
  content: '';

  position: relative;
  right: 0.9375rem;

  width: 0.1rem;
  height: 0.75rem;

  background: hsl(14 100% 65%);

  order: 1;
}

.primary-nav__more-toggle::after {
  content: '';

  width: 0.75rem;
  height: 0.1rem;

  background: hsl(14 100% 65%);
}

.primary-nav__more-drawer {
  display: none;
