<style lang="scss">
@import url(https://fonts.googleapis.com/css2?family=Jost:wght@100..900&display=swap);

body {
  background-color: hsl(0 0% 95%);
  
  font-family: Jost, sans-serif;
  font-weight: 450;
  letter-spacing: 0.5px;
}

header {
  margin-inline: auto;
  max-width: 100rem;

  background-color: hsl(0 0% 100%);
}

/* Primary Navigation */

.primary-nav {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
  align-items: flex-end;
  position: relative;
  
  padding: 1.25rem;
  border-bottom: 2px solid hsl(0 0% 93%);

  @media (min-width: 80rem) {
    padding-inline: 2.5rem;
  }
}

#menu-toggle {
  display: none;
}

#menu-toggle:checked {
  & ~ .primary-nav__logo {
    fill: hsl(0 0% 100%);
    transition: fill 150ms ease-in-out;
  }

  & ~ .primary-nav__menu-toggle {
    color: hsl(0 0% 100%);
    transition: color 150ms ease-in-out;
  }

  & ~ .primary-nav__menu-toggle::after {
    border-top: none;
    border-bottom: 5px solid hsl(0 0% 100%);
    transition: border-color 150ms ease-in-out;
  }

  & ~ .primary-nav__menu-drawer {
    transform: none;
  }
}

.primary-nav__logo {
  display: block;
  z-index: 1;

  width: 3.75rem;
  height: 1.75rem;

  transition: fill 150ms 200ms ease-in-out;
}

.primary-nav__menu-toggle {
  display: block flex;
  gap: 0.5rem;
  align-items: center;
  z-index: 1;

  height: 1.5rem;

  font-size: 1.125rem;

  transition: color 150ms 200ms ease-in-out;
  user-select: none;

  @media (min-width: 64rem) {
    display: none;
  }
}

.primary-nav__menu-toggle::after {
  content: '';

  border-top: 5px solid hsl(0 0% 0%);
  border-inline: 4px solid transparent;
  border-bottom: none;

  transition: border-color 150ms 200ms ease-in-out;
}

.primary-nav__menu-drawer {
  position: absolute;
  inset: 0;
  bottom: auto;

  padding-top: 4.25rem;
  padding-inline: 1rem;
  padding-bottom: 1rem;

  background-color: hsl(240 100% 50%);
  color: hsl(0 0% 100%);

  transform: translateY(-100%);
  transition: transform 350ms ease-in-out;

  @media (min-width: 64rem) {
    display: contents;
    position: static;

    padding-top: 0;

    color: hsl(0 0% 0%);
  }
}

.menu-drawer__main {
  @media (min-width: 64rem) {
    display: flex;
    flex: 1;
    gap: 1.75rem;
    align-items: center;

    margin-left: 0.5rem;
  }

  @media (min-width: 80rem) {
    gap: 2.25rem;
  }
}

.main-menu__item {
  margin-top: 0.25rem;
  margin-bottom: 1.4375rem;

  font-size: 1.125rem;

  @media (min-width: 64rem) {
    margin: 0;
  }
}

.main-menu__item--login {
  font-size: 0.75rem;
}

.main-menu__item--more {
